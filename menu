<!DOCTYPE html>
<html lang="ne">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Moon Light Cafe - Menu</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght=600;700&family=Poppins:wght=300;400;600;700&display=swap" rel="stylesheet">
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --gold: #C9A84C; --gold2: #E8C96A;
    --bg: #0a0a0a; --card: #161616; --card2: #1e1e1e;
    --text: #f0e6c8; --dim: #777;
    --green: #22c55e; --red: #ef4444; --orange: #f97316;
  }
  body { background: var(--bg); font-family: 'Poppins', sans-serif; color: var(--text); max-width: 480px; margin: 0 auto; min-height: 100vh; padding-bottom: 130px; }

  .header {
    background: linear-gradient(160deg, #1a1200 0%, #0a0800 100%);
    padding: 20px 20px 14px; text-align: center;
    border-bottom: 2px solid var(--gold);
    position: sticky; top: 0; z-index: 100;
  }
  .cafe-name { font-family: 'Cinzel', serif; font-size: 24px; font-weight: 900; color: var(--gold); letter-spacing: .12em; line-height: 1.1; }
  .cafe-sub { font-size: 10px; color: var(--dim); letter-spacing: .18em; margin-top: 4px; }
  .table-badge { display: inline-block; background: var(--gold); color: #000; font-size: 11px; font-weight: 700; padding: 3px 14px; border-radius: 20px; margin-top: 8px; }

  .search-wrap { padding: 12px 14px 0; }
  .search-input { width: 100%; background: var(--card); border: 1px solid #2a2a2a; border-radius: 25px; padding: 10px 18px; color: var(--text); font-size: 13px; font-family: 'Poppins', sans-serif; outline: none; }
  .search-input:focus { border-color: var(--gold); }
  .search-input::placeholder { color: var(--dim); }

  .tabs { display: flex; gap: 8px; padding: 12px 14px; overflow-x: auto; scrollbar-width: none; }
  .tabs::-webkit-scrollbar { display: none; }
  .tab { flex-shrink: 0; padding: 6px 13px; border-radius: 20px; font-size: 11px; font-weight: 600; border: 1px solid #2a2a2a; background: var(--card); color: var(--dim); cursor: pointer; transition: all .2s; white-space: nowrap; }
  .tab.active { background: var(--gold); color: #000; border-color: var(--gold); }

  .section { padding: 0 14px 10px; display: none; }
  .section.visible { display: block; }
  .sec-title { font-size: 12px; font-weight: 700; color: var(--gold); letter-spacing: .1em; text-transform: uppercase; margin-bottom: 8px; padding-top: 12px; display: flex; align-items: center; gap: 8px; }
  .sec-title::after { content: ''; flex: 1; height: 1px; background: #222; }

  .menu-card { display: flex; align-items: center; gap: 10px; background: var(--card); border-radius: 12px; padding: 11px 12px; margin-bottom: 7px; border: 1px solid #222; }
  .menu-card.bestseller { border-color: var(--gold); background: #1a1400; }
  .item-emoji { font-size: 26px; flex-shrink: 0; }
  .item-info { flex: 1; min-width: 0; }
  .item-name { font-size: 12px; font-weight: 600; color: var(--text); line-height: 1.3; }
  .item-desc { font-size: 10px; color: var(--dim); margin-top: 1px; }
  .item-price { font-size: 12px; font-weight: 700; color: var(--gold); margin-top: 2px; }
  .qty-ctrl { display: flex; align-items: center; gap: 6px; flex-shrink: 0; }
  .qty-btn { width: 26px; height: 26px; border-radius: 7px; border: none; font-size: 16px; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; }
  .qty-minus { background: #2a2a2a; color: var(--text); }
  .qty-plus { background: var(--gold); color: #000; }
  .qty-num { font-size: 13px; font-weight: 700; min-width: 14px; text-align: center; }

  .badge { font-size: 9px; padding: 2px 6px; border-radius: 8px; font-weight: 700; margin-left: 4px; vertical-align: middle; }
  .b-pop { background: var(--gold); color: #000; }
  .vd { display: inline-block; width: 7px; height: 7px; border-radius: 50%; margin-right: 3px; vertical-align: middle; }
  .veg { background: var(--green); }
  .nonveg { background: var(--red); }

  .cart-bar { position: fixed; bottom: 0; left: 50%; transform: translateX(-50%); width: 100%; max-width: 480px; background: var(--gold); color: #000; padding: 14px 20px; display: none; align-items: center; justify-content: space-between; font-weight: 700; font-size: 13px; z-index: 200; cursor: pointer; border-radius: 15px 15px 0 0; }
  .cart-bar.show { display: flex; }

  .overlay { position: fixed; inset: 0; background: rgba(0,0,0,.6); z-index: 250; display: none; }
  .overlay.show { display: block; }
  .cart-drawer { position: fixed; bottom: 0; left: 50%; transform: translateX(-50%) translateY(100%); width: 100%; max-width: 480px; background: #111; border-top: 2px solid var(--gold); border-radius: 20px 20px 0 0; padding: 20px 16px 30px; z-index: 300; transition: transform .3s; max-height: 80vh; overflow-y: auto; }
  .cart-drawer.open { transform: translateX(-50%) translateY(0); }
  .drawer-title { font-family: 'Cinzel', serif; font-size: 15px; font-weight: 700; color: var(--gold); margin-bottom: 14px; text-align: center; }
  .close-btn { position: absolute; top: 14px; right: 16px; background: none; border: none; color: var(--dim); font-size: 22px; cursor: pointer; }
  .cart-item { display: flex; justify-content: space-between; align-items: center; padding: 7px 0; border-bottom: 1px solid #1e1e1e; font-size: 12px; }
  .ci-name { flex: 1; color: var(--text); }
  .ci-qty { color: var(--dim); margin: 0 8px; }
  .ci-price { color: var(--gold); font-weight: 700; }
  .cart-total-row { display: flex; justify-content: space-between; font-size: 14px; font-weight: 700; margin-top: 12px; padding-top: 10px; border-top: 1px solid #2a2a2a; }
  .note-input { width: 100%; background: var(--card); border: 1px solid #2a2a2a; border-radius: 10px; padding: 10px 14px; color: var(--text); font-family: 'Poppins', sans-serif; font-size: 12px; margin: 12px 0; outline: none; resize: none; }
  .note-input:focus { border-color: var(--gold); }
  .order-btn { width: 100%; padding: 14px; background: var(--gold); color: #000; border: none; border-radius: 12px; font-size: 14px; font-weight: 700; cursor: pointer; font-family: 'Poppins', sans-serif; }
  .order-btn:disabled { opacity: .5; cursor: not-allowed; }

  .success-screen { position: fixed; inset: 0; background: #0a0a0a; display: none; flex-direction: column; align-items: center; justify-content: center; z-index: 500; text-align: center; padding: 30px; }
  .success-screen.show { display: flex; }
  .s-icon { font-size: 72px; margin-bottom: 16px; }
  .s-title { font-family: 'Cinzel', serif; font-size: 22px; color: var(--green); margin-bottom: 8px; }
  .s-msg { font-size: 13px; color: var(--dim); line-height: 1.7; }
  .back-btn { margin-top: 24px; padding: 12px 30px; background: var(--gold); color: #000; border: none; border-radius: 12px; font-size: 13px; font-weight: 700; cursor: pointer; font-family: 'Poppins', sans-serif; }
</style>

<!-- Firebase core र database पुस्तकालयहरू लोड गर्ने -->
<script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-app.js"></script>
<script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-database.js"></script>
</head>
<body>

<div class="header">
  <div style="font-size:28px;margin-bottom:2px">🌙</div>
  <div class="cafe-name">MOON LIGHT CAFE</div>
  <div class="cafe-sub">Good Coffee &nbsp;·&nbsp; Good Food &nbsp;·&nbsp; Good Moments</div>
  <div class="table-badge" id="table-badge">📍 Table &nbsp;—</div>
</div>

<div class="search-wrap">
  <input class="search-input" type="text" placeholder="🔍 Menu खोज्नुस्..." oninput="searchMenu(this.value)">
</div>

<div class="tabs">
  <div class="tab active" onclick="showCat('bestseller',this)">⭐ Best Sellers</div>
  <div class="tab" onclick="showCat('coffee',this)">☕ Coffee</div>
  <div class="tab" onclick="showCat('refreshers',this)">🍹 Refreshers</div>
  <div class="tab" onclick="showCat('bubbletea',this)">🧋 Bubble Tea</div>
  <div class="tab" onclick="showCat('momo',this)">🥟 Momo</div>
</div>

<!-- BEST SELLERS -->
<div class="section visible" data-cat="bestseller">
  <div class="sec-title">⭐ Best Sellers</div>
  <div class="menu-card bestseller" data-name="Moon Light Special Coffee"><div class="item-emoji">☕</div><div class="item-info"><div class="item-name"><span class="vd veg"></span>Moon Light Special Coffee<span class="badge b-pop">#1</span></div><div class="item-desc">House special blend</div><div class="item-price">Rs. 250</div></div><div class="qty-ctrl"><button class="qty-btn qty-minus" onclick="changeQty('Moon Light Special Coffee', -250, this)">−</button><span class="qty-num" id="qty-Moon-Light-Special-Coffee">0</span><button class="qty-btn qty-plus" onclick="changeQty('Moon Light Special Coffee', 250, this)">+</button></div></div>
  <div class="menu-card bestseller" data-name="Moon Light Special Mojito"><div class="item-emoji">🍹</div><div class="item-info"><div class="item-name"><span class="vd veg"></span>Moon Light Special Mojito<span class="badge b-pop">#2</span></div><div class="item-desc">Signature refresher</div><div class="item-price">Rs. 320</div></div><div class="qty-ctrl"><button class="qty-btn qty-minus" onclick="changeQty('Moon Light Special Mojito', -320, this)">−</button><span class="qty-num" id="qty-Moon-Light-Special-Mojito">0</span><button class="qty-btn qty-plus" onclick="changeQty('Moon Light Special Mojito', 320, this)">+</button></div></div>
</div>

<!-- COFFEE -->
<div class="section" data-cat="coffee">
  <div class="sec-title">☕ Hot Coffee</div>
  <div class="menu-card" data-name="Espresso"><div class="item-emoji">☕</div><div class="item-info"><div class="item-name"><span class="vd veg"></span>Espresso</div><div class="item-price">Rs. 100</div></div><div class="qty-ctrl"><button class="qty-btn qty-minus" onclick="changeQty('Espresso', -100, this)">−</button><span class="qty-num" id="qty-Espresso">0</span><button class="qty-btn qty-plus" onclick="changeQty('Espresso', 100, this)">+</button></div></div>
  <div class="menu-card" data-name="Cappuccino"><div class="item-emoji">☕</div><div class="item-info"><div class="item-name"><span class="vd veg"></span>Cappuccino</div><div class="item-price">Rs. 150</div></div><div class="qty-ctrl"><button class="qty-btn qty-minus" onclick="changeQty('Cappuccino', -150, this)">−</button><span class="qty-num" id="qty-Cappuccino">0</span><button class="qty-btn qty-plus" onclick="changeQty('Cappuccino', 150, this)">+</button></div></div>
</div>

<!-- REFRESHERS -->
<div class="section" data-cat="refreshers">
  <div class="sec-title">🍹 Refreshers</div>
  <div class="menu-card" data-name="Virgin Mojito"><div class="item-emoji">🍹</div><div class="item-info"><div class="item-name"><span class="vd veg"></span>Virgin Mojito</div><div class="item-price">Rs. 240</div></div><div class="qty-ctrl"><button class="qty-btn qty-minus" onclick="changeQty('Virgin Mojito', -240, this)">−</button><span class="qty-num" id="qty-Virgin-Mojito">0</span><button class="qty-btn qty-plus" onclick="changeQty('Virgin Mojito', 240, this)">+</button></div></div>
</div>

<!-- BUBBLE TEA -->
<div class="section" data-cat="bubbletea">
  <div class="sec-title">🧋 Bubble Tea</div>
  <div class="menu-card" data-name="Chocolate Bubble Tea"><div class="item-emoji">🍫</div><div class="item-info"><div class="item-name"><span class="vd veg"></span>Chocolate Bubble Tea</div><div class="item-price">Rs. 330</div></div><div class="qty-ctrl"><button class="qty-btn qty-minus" onclick="changeQty('Chocolate Bubble Tea', -330, this)">−</button><span class="qty-num" id="qty-Chocolate-Bubble-Tea">0</span><button class="qty-btn qty-plus" onclick="changeQty('Chocolate Bubble Tea', 330, this)">+</button></div></div>
</div>

<!-- MOMO -->
<div class="section" data-cat="momo">
  <div class="sec-title">🥟 Momo</div>
  <div class="menu-card" data-name="Chicken Momo"><div class="item-emoji">🥟</div><div class="item-info"><div class="item-name"><span class="vd nonveg"></span>Chicken Momo</div><div class="item-price">Rs. 120</div></div><div class="qty-ctrl"><button class="qty-btn qty-minus" onclick="changeQty('Chicken Momo', -120, this)">−</button><span class="qty-num" id="qty-Chicken-Momo">0</span><button class="qty-btn qty-plus" onclick="changeQty('Chicken Momo', 120, this)">+</button></div></div>
</div>

<!-- CART BAR -->
<div class="cart-bar" id="cart-bar" onclick="toggleCart(true)">
  <span id="cart-count">🛒 0 Items</span>
  <span id="cart-total">Total: Rs. 0 &nbsp;➔</span>
</div>

<!-- OVERLAY र CART DRAWER -->
<div class="overlay" id="overlay" onclick="toggleCart(false)"></div>
<div class="cart-drawer" id="cart-drawer">
  <button class="close-btn" onclick="toggleCart(false)">×</button>
  <div class="drawer-title">तपाईंको अर्डर विवरण</div>
  <div id="cart-items-list"></div>
  <div class="cart-total-row">
    <span>जम्मा रकम:</span>
    <span id="drawer-total">Rs. 0</span>
  </div>
  <textarea class="note-input" id="order-note" placeholder="केही विशेष अनुरोध छ? (जस्तै: कम पिरो, No Ice)"></textarea>
  <button class="order-btn" id="submit-order-btn" onclick="placeOrder()">Order पठाउनुस् 🌙</button>
</div>

<!-- SUCCESS SCREEN -->
<div class="success-screen" id="success-screen">
  <div class="s-icon">🎉</div>
  <div class="s-title">अर्डर सफल भयो!</div>
  <div class="s-msg">तपाईंको खाजा काउन्टरमा टिपाई सकियो।<br>कृपया केही बेर पर्खनुहोला। 😊</div>
  <button class="back-btn" onclick="resetCart()">थप अर्डर गर्नुस्</button>
</div>

<script>
// १. तपाईंको फायरबेस कन्फिगरेसन
const firebaseConfig = {
  apiKey: "AIzaSyDJ86I7sLw_4iW1FYnOUVGzJoo3z9n94Zc",
  authDomain: "menu-daef3.firebaseapp.com",
  databaseURL: "https://menu-daef3-default-rtdb.firebaseio.com",
  projectId: "menu-daef3",
  storageBucket: "menu-daef3.firebasestorage.app",
  messagingSenderId: "253545341756",
  appId: "1:253545341756:web:b52f94c9de580e5f657439",
  measurementId: "G-S43DRK2C94"
};
firebase.initializeApp(firebaseConfig);
const database = firebase.database();

// २. टेबल नम्बर लिने (URL बाट ?table=5 तान्ने)
const urlParams = new URLSearchParams(window.location.search);
const tableNum = urlParams.get('table') || "काउन्टर/पार्सल";
document.getElementById('table-badge').innerText = "📍 Table — " + tableNum;

let cart = {};

// ३. क्याटगोरी मेनु नेभिगेसन
function showCat(catId, btn) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.section').forEach(s => s.classList.remove('visible'));
  btn.classList.add('active');
  document.querySelector(`[data-cat="${catId}"]`).classList.add('visible');
}

// ४. सर्च फङ्सन
function searchMenu(query) {
  let q = query.toLowerCase();
  document.querySelectorAll('.menu-card').forEach(card => {
    let name = card.getAttribute('data-name').toLowerCase();
    if(name.includes(q)) {
      card.style.display = 'flex';
    } else {
      card.style.display = 'none';
    }
  });
}

// ५. परिमाण बढाउने वा घटाउने
function changeQty(name, price, btn) {
  if (!cart[name]) {
    cart[name] = { qty: 0, price: Math.abs(price) };
  }
  
  if (price > 0) {
    cart[name].qty += 1;
  } else {
    cart[name].qty -= 1;
    if (cart[name].qty <= 0) delete cart[name];
  }
  
  // स्क्रिनमा नम्बर अपडेट गर्ने
  let idName = "qty-" + name.replace(/ /g, "-");
  let element = document.getElementById(idName);
  if(element) {
    element.innerText = cart[name] ? cart[name].qty : 0;
  }
  
  updateCartBar();
}

// ६. कार्ट बार अपडेट गर्ने
function updateCartBar() {
  let totalItems = 0;
  let totalPrice = 0;
  
  for (let key in cart) {
    totalItems += cart[key].qty;
    totalPrice += (cart[key].qty * cart[key].price);
  }
  
  let cartBar = document.getElementById('cart-bar');
  if (totalItems > 0) {
    cartBar.classList.add('show');
    document.getElementById('cart-count').innerText = `🛒 ${totalItems} आइटम`;
    document.getElementById('cart-total').innerText = `Total: Rs. ${totalPrice} ➔`;
  } else {
    cartBar.classList.remove('show');
    toggleCart(false);
  }
}

// ७. कार्ट ड्रअर खोल्ने वा बन्द गर्ने
function toggleCart(show) {
  let drawer = document.getElementById('cart-drawer');
  let overlay = document.getElementById('overlay');
  if (show) {
    buildCartList();
    drawer.classList.add('open');
    overlay.classList.add('show');
  } else {
    drawer.classList.remove('open');
    overlay.classList.remove('show');
  }
}

// ८. कार्ट भित्र आइटमको सूची बनाउने
function buildCartList() {
  let listDiv = document.getElementById('cart-items-list');
  listDiv.innerHTML = "";
  let totalPrice = 0;
  
  for (let name in cart) {
    let cost = cart[name].qty * cart[name].price;
    totalPrice += cost;
    listDiv.innerHTML += `
      <div class="cart-item">
        <span class="ci-name">${name}</span>
        <span class="ci-qty">x${cart[name].qty}</span>
        <span class="ci-price">Rs. ${cost}</span>
      </div>
    `;
  }
  document.getElementById('drawer-total').innerText = "Rs. " + totalPrice;
}

// ९. फायरबेसमा अर्डर पठाउने मुख्य फङ्सन
function placeOrder() {
  let btn = document.getElementById('submit-order-btn');
  btn.disabled = true;
  btn.innerText = "पठाउँदै...";

  let orderItems = [];
  let totalPrice = 0;
  
  for (let name in cart) {
    orderItems.push({
      item_name: name,
      qty: cart[name].qty,
      price: cart[name].price
    });
    totalPrice += (cart[name].qty * cart[name].price);
  }

  let note = document.getElementById('order-note').value;

  // Realtime Database मा डाटा हाल्ने
  database.ref('orders').push({
    table: tableNum,
    items: orderItems,
    total: totalPrice,
    note: note,
    status: "New",
    timestamp: Date.now()
  }).then(() => {
    document.getElementById('success-screen').classList.add('show');
  }).catch((err) => {
    alert("माफ गर्नुहोला, अर्डर सफल भएन। फेरि प्रयास गर्नुहोला। " + err.message);
    btn.disabled = false;
    btn.innerText = "Order पठाउनुस् 🌙";
  });
}

// १०. अर्डर सफल भएपछि कार्ट सफा गर्ने
function resetCart() {
  cart = {};
  document.querySelectorAll('.qty-num').forEach(el => el.innerText = "0");
  document.getElementById('order-note').value = "";
  updateCartBar();
  document.getElementById('success-screen').classList.remove('show');
  document.getElementById('submit-order-btn').disabled = false;
  document.getElementById('submit-order-btn').innerText = "Order पठाउनुस् 🌙";
}
</script>
</body>
</html>
